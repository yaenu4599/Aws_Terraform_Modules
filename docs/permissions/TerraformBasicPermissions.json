{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "BasicCreate",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateTags"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/ManagedBy": "terraform"
                }
            }
        },
        {
            "Sid": "BasicDelete",
            "Effect": "Allow",
            "Action": [
                "ec2:DeleteTags"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:ResourceTag/ManagedBy": "terraform"
                }
            }
        }
    ]
}